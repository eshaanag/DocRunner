{
  "name": "docrunner",
  "version": "0.1.0",
  "description": "CLI that validates and runs README code snippets.",
  "type": "module",
  "bin": {
    "docrunner": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@types/mdast": "^4.0.4",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "mdast-util-to-string": "^4.0.0",
    "remark-parse": "^11.0.0",
    "ts-node": "^10.9.2",
    "unified": "^11.0.5",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.8"
  }
}
